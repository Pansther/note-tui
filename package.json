{
	"name": "note-tui",
	"version": "0.0.0",
	"license": "MIT",
	"bin": "dist/cli.js",
	"type": "module",
	"engines": {
		"node": ">=16"
	},
	"scripts": {
		"build": "tsc",
		"build:dev": "tsc --noResolve --noCheck",
		"dev": "yarn tsx watch source/cli.tsx",
		"start": "yarn tsx source/cli.tsx",
		"test": "prettier --check . && xo && ava"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"clsx": "^2.1.1",
		"dayjs": "^1.11.19",
		"immer": "^11.1.4",
		"ink": "^6.8.0",
		"ink-scroll-list": "^0.4.1",
		"ink-scroll-view": "^0.3.6",
		"ink-text-input": "^6.0.0",
		"marked": "^17.0.3",
		"marked-terminal": "^7.3.0",
		"meow": "^11.0.0",
		"nanoid": "^5.1.6",
		"react": "^19.2.4",
		"tsx": "^4.21.0",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^3.0.1",
		"@types/marked-terminal": "^6.1.1",
		"@types/react": "^19.2.14",
		"@vdemedes/prettier-config": "^2.0.1",
		"ava": "^5.2.0",
		"chalk": "^5.6.2",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"ink-testing-library": "^3.0.0",
		"prettier": "^2.8.7",
		"ts-node": "^10.9.1",
		"typescript": "^5.0.3",
		"xo": "^0.53.1"
	},
	"ava": {
		"extensions": {
			"ts": "module",
			"tsx": "module"
		},
		"nodeArguments": [
			"--loader=ts-node/esm"
		]
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"rules": {
			"react/prop-types": "off"
		}
	},
	"prettier": "@vdemedes/prettier-config"
}
